# FM Live Wire — environment template.
# Copy to `.env` and fill values. `.env` is gitignored.
#
# SECURITY (AD-10): OWNER_SECRET is a SERVER-ONLY secret.
# It MUST NEVER be exposed to the Vite bundle — never use a `VITE_` prefix
# for OWNER_SECRET or any server secret. Performer auth is a manual token
# entered per-session, sent via socket.auth.token at handshake.

# Server-only owner auth secret (high-entropy random string). Server-only.
OWNER_SECRET=

# Public origin the server is served from (single-origin HTTPS, AD-15).
PUBLIC_ORIGIN=

# HTTP port for the mono-process Express + Socket.IO server.
PORT=

# Set to 1 to log full MIDI event flow in dev (AD-18). Leave empty otherwise.
LOG_MIDI=

# Optional guard: max concurrent listeners. Leave empty for default.
MAX_LISTENERS=